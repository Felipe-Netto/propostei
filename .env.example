# ============================================================
# .env.example — template for production environment variables
#
# On the server, copy this file to .env.prod and fill in real values:
#   cp .env.example .env.prod
#
# NEVER commit .env.prod or any file with real secrets.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=propostei_db

# Full connection string consumed by Prisma (must match the values above)
DATABASE_URL=postgresql://postgres:change_me@postgres:5432/propostei_db

# --- NestJS API ---
PORT=3000
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# URL of the frontend, used by NestJS to set the CORS allowed origin
# (maps to URL_WEB in the api source)
FRONTEND_URL=https://yourdomain.com
